<?xml version="1.0"?>
<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:noNamespaceSchemaLocation="urn:magento:module:Magento_Config:etc/system_file.xsd">
    <system>
        <tab id="etechflow" translate="label" sortOrder="400">
            <label>eTechFlow</label>
        </tab>
        <section id="etechflow_productwarning"
                 translate="label"
                 type="text"
                 sortOrder="170"
                 showInDefault="1"
                 showInWebsite="1"
                 showInStore="1">
            <label>Product Warning</label>
            <tab>etechflow</tab>
            <resource>ETechFlow_ProductWarning::warnings</resource>

            <group id="module_status" translate="label" type="text" sortOrder="0" showInDefault="1" showInWebsite="1" showInStore="1">
                <label>Module Status</label>
                <frontend_model>ETechFlow\ProductWarning\Block\Adminhtml\System\Config\ModuleStatus</frontend_model>
            </group>

            <group id="license" translate="label" type="text" sortOrder="1" showInDefault="1" showInWebsite="0" showInStore="0">
                <label>License</label>
                <comment><![CDATA[A valid licence is always required — there is no environment toggle and no host bypass. On a dev/staging box, enter a per-module HMAC key in the License Key field.]]></comment>
                <field id="license_key" translate="label comment" type="text" sortOrder="10" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Key</label>
                    <comment><![CDATA[
                        Paste the SP-XXXX key from your purchase email, or a per-module HMAC key, or a
                        shared eTechFlow bundle key. Bound to the domain you provided at checkout.<br/>
                        A valid licence is required on every host. <code>www.</code> prefix is normalised.
                    ]]></comment>
                </field>
                <field id="bundle_license_key" translate="label comment" type="obscure" sortOrder="15" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Bundle License Key</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <config_path>etechflow_bundle/license/license_key</config_path>
                    <comment><![CDATA[
                        Shared key across ALL eTechFlow modules. If you purchased the eTechFlow Bundle,
                        paste it here once and every installed eTechFlow module activates.<br/>
                        Stored encrypted.
                    ]]></comment>
                </field>
                <field id="portal_url" translate="label comment" type="text" sortOrder="20" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>License Portal URL</label>
                    <comment><![CDATA[
                        The eTechFlow portal endpoint that validates SP-XXXX subscription keys.
                        Default: <code>https://subpanel-paralyses-president.ngrok-free.dev/license/validate</code>.
                        Change only if eTechFlow notifies you of a new portal URL.
                    ]]></comment>
                </field>
                <field id="issued_key" translate="label" type="obscure" sortOrder="30" showInDefault="1" showInWebsite="0" showInStore="0">
                    <label>Last Issued Key (auto-managed)</label>
                    <backend_model>Magento\Config\Model\Config\Backend\Encrypted</backend_model>
                    <comment><![CDATA[
                        Read-only audit field. Auto-populated when the portal accepts a key for the first time.
                        Used by the module to auto-restore the licence after a portal IP-block lift.
                        Do not edit manually.
                    ]]></comment>
                </field>
            </group>


            <group id="general"
                   translate="label"
                   type="text"
                   sortOrder="10"
                   showInDefault="1"
                   showInWebsite="1"
                   showInStore="1">
                <label>General Settings</label>
                <field id="enabled"
                       translate="label comment tooltip"
                       type="select"
                       sortOrder="10"
                       showInDefault="1"
                       showInWebsite="1"
                       showInStore="1">
                    <label>Enable Module</label>
                    <source_model>Magento\Config\Model\Config\Source\Yesno</source_model>
                    <tooltip>Master on/off. When No, no warnings render anywhere on the storefront.</tooltip>
                    <comment><![CDATA[
                        Master on/off switch.<br/>
                        <strong>Yes</strong> = warnings render on assigned products' PDPs.<br/>
                        <strong>No</strong> = no warnings render anywhere — useful for quickly disabling
                        the module without uninstalling.
                    ]]></comment>
                </field>
            </group>
        </section>
    </system>
</config>
