<?xml version="1.0"?>
<!--
  Auto-injects the warning notice block into the product detail page on
  every theme. Targets product.info.main — the standard container in
  both Luma and Hyvä themes.

  Stores that want to move the block elsewhere (e.g. above the price)
  can override this file in their own theme and change the
  referenceContainer name and `before`/`after` arguments.
-->
<page xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
      xsi:noNamespaceSchemaLocation="urn:magento:framework:View/Layout/etc/page_configuration.xsd">
    <body>
        <referenceContainer name="product.info.main">
            <block class="ETechFlow\ProductWarning\Block\Frontend\Notice"
                   name="etechflow.product.warning.notice"
                   template="ETechFlow_ProductWarning::notice.phtml"
                   before="product.info.price"
                   cacheable="true"/>
        </referenceContainer>
    </body>
</page>
